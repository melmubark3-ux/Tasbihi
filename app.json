{
  "expo": {
    "name": "تسبيحي",
    "slug": "tasbihi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tasbihi.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20"
      },
      "package": "com.tasbihi.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "userInterfaceStyle": "light"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-updates",
      "expo-location",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8efa6581-765a-473d-9109-09466f0089ab"
      }
    },
    "owner": "melmubark2"
  }
}